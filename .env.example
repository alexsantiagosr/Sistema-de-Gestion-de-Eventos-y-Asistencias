# ===========================================
# SGEH - Variables de Entorno para Producción
# ===========================================
# Copia este archivo a .env y completa los valores

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Obtén estos valores de tu proyecto en Supabase Dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Genera un secreto fuerte para producción
# Usa: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
